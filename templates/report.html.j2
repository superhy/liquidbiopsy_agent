<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>cfDNA Agent Report</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; }
    h1, h2, h3 { color: #1a3b5d; }
    table { border-collapse: collapse; width: 100%; margin-bottom: 16px; }
    th, td { border: 1px solid #ccc; padding: 6px; text-align: left; }
    .section { margin-bottom: 24px; }
  </style>
</head>
<body>
  <h1>Cell-free DNA Cohort Report</h1>
  <p>This summary is generated automatically in British English and reflects the data processed in this run. Figures are intentionally concise to guide next analytical steps.</p>

  <div class="section">
    <h2>Dataset Overview</h2>
    <p>Samples analysed: {{ n_samples }}.</p>
  </div>

  <div class="section">
    <h2>Quality Control</h2>
    {% if qc_table %}
    <table>
      <tr>{% for k in qc_table[0].keys() %}<th>{{ k }}</th>{% endfor %}</tr>
      {% for row in qc_table %}
      <tr>{% for v in row.values() %}<td>{{ v }}</td>{% endfor %}</tr>
      {% endfor %}
    </table>
    {% else %}
      <p>No QC metrics available.</p>
    {% endif %}
    {% if length_plot %}
      <img src="data:image/png;base64,{{ length_plot }}" alt="Length distribution" style="max-width: 600px;" />
    {% endif %}
    {% if coverage_heatmap %}
      <img src="data:image/png;base64,{{ coverage_heatmap }}" alt="Coverage uniformity heatmap" style="max-width: 700px;" />
    {% endif %}
    {% if coverage_bin_heatmap %}
      <img src="data:image/png;base64,{{ coverage_bin_heatmap }}" alt="Coverage bin heatmap" style="max-width: 700px;" />
    {% endif %}
  </div>

  <div class="section">
    <h2>CNV Overview</h2>
    {% if cnv_preview %}
      <p>Example smoothed CNV profile (first sample in manifest).</p>
      <img src="data:image/png;base64,{{ cnv_preview }}" alt="CNV profile" style="max-width: 700px;" />
    {% else %}
      <p>No CNV profile preview available.</p>
    {% endif %}
    {% if cnv_chrom_preview %}
      <p>Chromosome-binned CNV profile.</p>
      <img src="data:image/png;base64,{{ cnv_chrom_preview }}" alt="CNV chromosome plot" style="max-width: 700px;" />
    {% endif %}
  </div>

  <div class="section">
    <h2>Fragmentomics Peaks</h2>
    {% if length_peaks %}
      <img src="data:image/png;base64,{{ length_peaks }}" alt="Length peak comparison" style="max-width: 700px;" />
    {% else %}
      <p>No length peak comparison plot available.</p>
    {% endif %}
    {% if length_violin %}
      <img src="data:image/png;base64,{{ length_violin }}" alt="Length violin plot" style="max-width: 700px;" />
    {% endif %}
  </div>

  <div class="section">
    <h2>Feature Snapshot</h2>
    {% if features_table %}
    <table>
      <tr>{% for k in features_table[0].keys() %}<th>{{ k }}</th>{% endfor %}</tr>
      {% for row in features_table %}
      <tr>{% for v in row.values() %}<td>{{ v }}</td>{% endfor %}</tr>
      {% endfor %}
    </table>
    {% else %}
      <p>No feature table available.</p>
    {% endif %}
    {% if pca_plot %}
      <img src="data:image/png;base64,{{ pca_plot }}" alt="PCA" style="max-width: 600px;" />
    {% endif %}
  </div>

  <div class="section">
    <h2>Drift and Outliers</h2>
    {% if drift %}
      <pre>{{ drift | tojson(indent=2) }}</pre>
    {% else %}
      <p>No drift flags triggered; the cohort appears stable under current thresholds.</p>
    {% endif %}
  </div>

  <div class="section">
    <h2>Agent Interpretation</h2>
    {% if agent_explanation %}
      <p>{{ agent_explanation }}</p>
    {% else %}
      <p>No agent interpretation was generated for this run.</p>
    {% endif %}
    {% if agent_summary.parameter_tuning %}
      <h3>Suggested Parameter Tuning</h3>
      <pre>{{ agent_summary.parameter_tuning | tojson(indent=2) }}</pre>
    {% endif %}
    {% if agent_summary.rerun_samples %}
      <h3>Suggested Reruns</h3>
      <pre>{{ agent_summary.rerun_samples | tojson(indent=2) }}</pre>
    {% endif %}
  </div>

  <div class="section">
    <h2>Next Recommendations</h2>
    <p>Consider reviewing samples with high fragment length dispersion or elevated chromosome Y fraction. Where CNV amplitudes are broad, a finer bin size or GC correction may be worthwhile. Replace the demonstration methylation panels with study-specific targets for richer biological signal.</p>
  </div>
</body>
</html>
